# MoneyPrinterTurbo (Layer 3) — environment configuration
#
# Most config lives in config.toml. This file holds env-vars that are
# set per-environment (dev/staging/prod) AND must match Layer 2's values.

# --- Spec 014 (orchestration) ---

# JWT signing key (HS256). MUST match Layer 2's LAYER2_JWT_SIGNING_KEY.
# Generate via: openssl rand -hex 32
LAYER2_JWT_SIGNING_KEY=changeme-generate-via-openssl-rand-hex-32

# When true: skip JWT verification on requests from 127.0.0.1 (legacy
# upstream MPT WebUI compatibility). MUST be false in production.
LAYER3_TRUST_LOCAL_UPSTREAM=false

# When true: VideoParams.tenant_id + user_id MUST be non-empty.
# Production should set this to true after Step 2 lands; dev keeps false
# during the transition window so legacy callers don't break mid-deploy.
LAYER3_REQUIRE_TENANT_CONTEXT=false

# Environment marker for the production-safety-guard at startup.
LAYER3_ENV=development

# === Spec 018 — Mode 4 UGC Avatar Generator (MuseTalk lip-sync) ===
#
# Engine selector. "musetalk" runs real lip-sync inference (requires
# CUDA on Linux production hosts OR PyTorch MPS on Apple Silicon dev with
# slower throughput). "mock" copies the speaker reference verbatim to
# output without inference — useful in CI, on hosts without GPU/MPS, and
# for iterating on L1+L2 wiring without paying the lip-sync wall time.
LIP_SYNC_ENGINE=mock

# Where MuseTalk model weights are cached / loaded from. The vendored
# install script (scripts/install_musetalk.sh) downloads ~2GB into this
# directory on first run.
MUSETALK_MODEL_DIR=~/.cache/musetalk

# Optional override for the inference device. When unset, lip_sync.py
# auto-detects: cuda → mps → cpu (in priority order).
# MUSETALK_DEVICE=cuda

# Optional crossfade duration at ping-pong loop seams (FR-015 audio
# overflow). Default 0.0 = pure pivot (research.md R5). Bump to 0.10s if
# the pure pivot ever shows visible jumps for a particular speaker
# reference's motion characteristics.
LIP_SYNC_LOOP_SEAM_FADE_SECONDS=0.0
